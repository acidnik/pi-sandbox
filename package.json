{
  "name": "@oddsjam/pi-sandbox",
  "version": "0.1.0",
  "description": "OS-level sandbox for pi using @anthropic-ai/sandbox-runtime, with an in-pi configure wizard, shift+tab toggle, and longest-prefix project configs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oddsjam/pi-sandbox.git"
  },
  "homepage": "https://github.com/oddsjam/pi-sandbox#readme",
  "bugs": {
    "url": "https://github.com/oddsjam/pi-sandbox/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "sandbox",
    "security",
    "permissions",
    "bubblewrap",
    "seccomp",
    "sandbox-exec",
    "tui"
  ],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "screenshots/**/*.png",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "./screenshots/sandbox-configure.png"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.51"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^24",
    "typescript": "^5.6.0"
  },
  "trustedDependencies": [
    "@anthropic-ai/sandbox-runtime"
  ]
}
